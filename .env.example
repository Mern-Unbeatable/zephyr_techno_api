# Server Configuration
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
OTP_EXPIRES_MINUTES=10

# Database Configuration
# Replace with your actual database URL
# For PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For MySQL: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# For SQLite: file:./dev.db
DATABASE_URL="postgresql://postgres:password@localhost:5432/mydb"

# Mail Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=no-reply@example.com
MAIL_PASS=replace-with-mail-password
MAIL_FROM="Zephyr Techno <no-reply@example.com>"

# Newsletter — notification recipient when someone subscribes
NEWSLETTER_NOTIFY_EMAIL=ali@zephyrtechnology.co.uk

# Stripe
# Your Stripe secret key (keep this private) and publishable key (used on client)
STRIPE_SECRET=sk_test_replace_with_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_key
STRIPE_SUCCESS_URL=http://localhost:5173/checkout/success
STRIPE_CANCEL_URL=http://localhost:5173/checkout/cancel
LIVE_URL=https://api.example.com

# Comma-separated frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,https://zephyrtechnology.co.uk,https://www.zephyrtechnology.co.uk

# Embed signature icons in email (recommended — avoids external image hosts)
SIGNATURE_USE_CID=true
